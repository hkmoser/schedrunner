# ha-events configuration
# Copy to .env and fill in values

# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here
# Event types to subscribe to (comma-separated). Defaults to EVERY event type.
# Set a list to narrow it down; "*" or "all" (or empty) means every type.
# Examples: *   |   state_changed   |   state_changed,call_service,automation_triggered
HA_EVENT_TYPES=*

# Philips Hue (run setup_hue.py once to get this)
HUE_IP=192.168.4.41
HUE_KEY=your_hue_application_key_here

# YoLink (from Homebridge config)
YOLINK_USER_ACCESS_ID=ua_B72C13532D2F4742AF337F71BAC93E37
YOLINK_SECRET_KEY=sec_v1_voeVoist6cC9J2U8quOc2w==
YOLINK_TOKEN_URL=https://api.yosmart.com/open/yolink/token
YOLINK_API_URL=https://api.yosmart.com/open/yolink/v2/api
YOLINK_MQTT_HOST=api.yosmart.com
YOLINK_MQTT_PORT=8003

# eero (run setup_eero.py once to log in and obtain this)
EERO_SESSION_TOKEN=your_eero_session_token_here
# How often to poll the eero cloud API, in seconds
EERO_POLL_INTERVAL=300
# Activity series to record (comma-separated): data_usage works on any
# account; blocked, inspected, adblock require an eero Secure subscription.
EERO_ACTIVITY_TYPES=data_usage
# Activity window: day (hourly), week, or month (both daily).
EERO_ACTIVITY_PERIOD=day
# Optional overrides:
# EERO_API_URL=https://api-user.e2ro.com

# Storage
DB_PATH=/Users/joemoser/Dropbox/Source/ha-events/events.db
GDRIVE_PATH=/Users/joemoser/CloudStorage/GoogleDrive-joe@joemoser.com/My Drive/Smart Home Events

# Sync interval in seconds (how often to write summary to Drive)
DRIVE_SYNC_INTERVAL=300
