{
  "type": "screen",
  "style": { "background": "$bg" },
  "children": [
    {
      "type": "scroll",
      "children": [
        {
          "type": "vstack",
          "style": { "spacing": 12, "padding": 16 },
          "children": [
            {
              "type": "hstack",
              "style": { "align": "center" },
              "children": [
                { "type": "text", "binding": "afmlog.title", "style": { "font": "largeTitle", "weight": "bold", "color": "$textPrimary" } },
                { "type": "spacer" },
                { "type": "text", "binding": "meta.updatedAtFormatted", "style": { "font": "caption", "color": "$textSecondary" }, "action": { "type": "refresh" } }
              ]
            },
            { "type": "text", "binding": "afmlog.subtitleFormatted", "style": { "font": "caption", "color": "$textSecondary" } },
            {
              "type": "hstack",
              "props": { "repeat": "afmlog.ranges" },
              "style": { "spacing": 8, "wrap": true },
              "children": [
                { "type": "badge", "binding": "item.labelFormatted", "style": { "color": "item.color" }, "action": { "type": "navigate", "urlBinding": "item.navHref" } }
              ]
            },
            { "type": "text", "binding": "afmlog.emptyFormatted", "style": { "font": "subhead", "color": "$textSecondary", "align": "center" } },
            {
              "type": "card",
              "style": { "background": "$cardBg", "cornerRadius": 16, "padding": 8 },
              "children": [
                {
                  "type": "vstack",
                  "props": { "repeat": "afmlog.events" },
                  "style": { "spacing": 2 },
                  "children": [
                    {
                      "type": "hstack",
                      "style": { "align": "center", "spacing": 10, "padding": 6 },
                      "children": [
                        { "type": "text", "binding": "item.timeFormatted", "style": { "font": "caption", "weight": "semibold", "color": "$textSecondary", "width": 96 } },
                        { "type": "image", "binding": "item.icon", "style": { "font": "body", "color": "item.color" } },
                        { "type": "text", "binding": "item.lineFormatted", "style": { "font": "subhead", "color": "$textPrimary" } }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
