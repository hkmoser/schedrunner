{
  "type": "screen",
  "style": { "background": "$bg" },
  "children": [
    {
      "type": "scroll",
      "children": [
        {
          "type": "vstack",
          "style": { "spacing": 16, "padding": 16 },
          "children": [
            {
              "type": "hstack",
              "style": { "align": "center" },
              "children": [
                { "type": "text", "binding": "balances.title", "style": { "font": "largeTitle", "weight": "bold", "color": "$textPrimary" } },
                { "type": "spacer" },
                { "type": "text", "binding": "meta.updatedAtFormatted", "style": { "font": "caption", "color": "$textSecondary" }, "action": { "type": "refresh" } }
              ]
            },
            {
              "type": "card",
              "style": { "background": "$cardBg", "cornerRadius": 20, "padding": 16 },
              "children": [
                { "type": "text", "props": { "text": "Net" }, "style": { "font": "subhead", "color": "$textSecondary" } },
                { "type": "text", "binding": "balances.netFormatted", "style": { "font": "largeTitle", "weight": "bold", "color": "balances.netDirection" } },
                { "type": "text", "binding": "balances.subtitleFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
              ]
            },
            {
              "type": "vstack",
              "props": { "repeat": "balances.netWorthCards" },
              "style": { "spacing": 16 },
              "children": [
                {
                  "type": "card",
                  "style": { "background": "$cardBg", "cornerRadius": 20, "padding": 16 },
                  "children": [
                    {
                      "type": "hstack",
                      "style": { "align": "center", "spacing": 8 },
                      "children": [
                        { "type": "text", "binding": "item.titleFormatted", "style": { "font": "headline", "weight": "bold", "color": "$textPrimary" } },
                        { "type": "spacer" },
                        { "type": "text", "binding": "item.currentFormatted", "style": { "font": "headline", "weight": "bold", "color": "item.currentDirection" } }
                      ]
                    },
                    { "type": "lineChart", "binding": "item.series", "style": { "height": 160 } },
                    {
                      "type": "hstack",
                      "style": { "align": "center", "spacing": 8 },
                      "children": [
                        { "type": "text", "binding": "item.changeFormatted", "style": { "font": "caption", "weight": "semibold", "color": "item.changeDirection" } },
                        { "type": "spacer" },
                        { "type": "text", "binding": "item.rangeFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
                      ]
                    },
                    { "type": "text", "binding": "item.spanFormatted", "style": { "font": "caption", "color": "$textSecondary" } },
                    { "type": "text", "binding": "item.footnoteFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
                  ]
                }
              ]
            },
            {
              "type": "vstack",
              "props": { "repeat": "balances.groups" },
              "style": { "spacing": 16 },
              "children": [
                {
                  "type": "card",
                  "style": { "background": "$cardBg", "cornerRadius": 20, "padding": 16 },
                  "children": [
                    {
                      "type": "hstack",
                      "style": { "align": "center", "spacing": 8 },
                      "children": [
                        { "type": "text", "binding": "item.title", "style": { "font": "headline", "weight": "bold", "color": "$textPrimary" } },
                        { "type": "spacer" },
                        { "type": "text", "binding": "item.subtotalFormatted", "style": { "font": "headline", "weight": "bold", "color": "item.subtotalDirection" } }
                      ]
                    },
                    { "type": "divider", "style": { "color": "$divider" } },
                    {
                      "type": "vstack",
                      "props": { "repeat": "item.accounts" },
                      "style": { "spacing": 14 },
                      "children": [
                        {
                          "type": "hstack",
                          "style": { "align": "center" },
                          "children": [
                            {
                              "type": "vstack",
                              "style": { "spacing": 2 },
                              "children": [
                                { "type": "text", "binding": "item.name", "style": { "font": "body", "weight": "semibold", "color": "$textPrimary" } },
                                { "type": "text", "binding": "item.kind", "style": { "font": "caption", "color": "$textSecondary" } }
                              ]
                            },
                            { "type": "spacer" },
                            { "type": "text", "binding": "item.balanceFormatted", "style": { "font": "headline", "weight": "semibold", "color": "item.direction" } }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
