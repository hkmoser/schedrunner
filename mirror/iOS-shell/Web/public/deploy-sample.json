      "remedyFormatted": "Tap Redeploy to rebuild the server from the checked-out commit (e4f5g6h).",
      "redeployActions": [
        {
          "labelFormatted": "Redeploy now"
        }
      ],
      "deployLogLabel": "Last deploy run · 3m ago",
