          "behindNote": "",
          "rebaseActions": []
        },
        {
          "name": "wip-fix",
          "labelFormatted": "wip-fix",
          "metaFormatted": "↑2 unmerged → main · ↓3 behind",
          "shipPostHref": "/repos_pr?owner=hkmoser&name=ios-shell&branch=wip-fix&base=main&pr=",
          "behindNote": "↓3 behind main — rebase recommended before shipping",
          "rebaseActions": [
            {
              "labelFormatted": "Rebase onto main & ship",
              "postHref": "/repos_pr?owner=hkmoser&name=ios-shell&branch=wip-fix&base=main&pr=&rebase=1"
            }
          ]
        }
      ],
      "ciStages": [
        {
          "nameFormatted": "✓ server-ci",
