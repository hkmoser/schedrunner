      "iosDetailFormatted": "OTA published — tap the install button to put it on the phone.",
      "iosAutoBuildFormatted": "iOS auto-build: ON",
      "autoDeployFormatted": "Post-pull hook: SUCCESS(e4f5g6h) 2026-07-05 09:14:02",
      "logLabel": "iOS build log (last 60 lines)",
      "logFormatted": "== build & install OTA ==\nxcodebuild archive…\n** ARCHIVE SUCCEEDED **\nexported Dashboard.ipa\n[ios-autodeploy] SUCCESS build 251",
      "ciFormatted": "CI running · 1m ago",
      "ciDirection": "#6ea8fe",
      "installActions": [
        {
          "labelFormatted": "Install iOS app · v0.1.251 (build 251)",
          "installURL": "itms-services://?action=download-manifest&url=https://macmini.example.ts.net/app/manifest.plist"
