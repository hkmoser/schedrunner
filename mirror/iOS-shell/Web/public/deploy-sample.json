        },
        {
          "nameFormatted": "⏳ ios-ci · running",
          "direction": "#6ea8fe"
        },
        {
          "nameFormatted": "◦ web-ci · queued",
          "direction": "#9aa4c4"
        }
      ],
      "ciRunUrl": "https://github.com/hkmoser/ios-shell/actions/runs/123",
