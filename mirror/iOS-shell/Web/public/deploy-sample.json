{
  "schemaVersion": 1,
  "theme": {
    "colors": {
      "bg": "#0b1020",
      "bgAccent": "#16204a",
      "cardBg": "#161c2e",
      "textPrimary": "#f2f5ff",
      "textSecondary": "#9aa4c4",
      "accent": "#6ea8fe",
      "up": "#43d18a",
      "down": "#ff6b6b",
      "divider": "#2a3350"
    },
    "fonts": {
      "family": "-apple-system, system-ui, sans-serif"
    },
    "spacing": 12,
    "radius": 20
  },
  "data": {
    "meta": {
      "updatedAtFormatted": "Updated just now",
      "stale": false
    },
    "deploy": {
