# Copy to .env and fill in. Never commit .env.
# These are needed by setup.sh — wrangler reads them from the environment.

# From https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Workers Scripts:Edit, Zone:Read, DNS:Edit
CLOUDFLARE_API_TOKEN=

# From https://dash.cloudflare.com — top-right account switcher → copy Account ID
CLOUDFLARE_ACCOUNT_ID=
