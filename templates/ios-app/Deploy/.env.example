# Copy to Deploy/.env and fill in. Deploy/.env is git-ignored — never commit secrets.
# Loaded by the server (via launchd) and by the deploy scripts.

# --- Tailscale host (your Mac mini's MagicDNS name; `tailscale status` shows it) ---
# Example: macmini.tailnet-abcd.ts.net  (no scheme, no trailing slash)
TS_HOST=

# --- Server ---
PORT=8080
# Absolute path to the built web bundle. `make deploy` sets this automatically;
# only override if you relocate the repo.
# WEB_DIST=/Users/you/iOS-Shell/Web/dist

# --- Background cache warming ---
# Keep the provider cache fresh on a timer so opening the app (even briefly before going
# offline) shows the absolute latest, instead of fetching lazily on the first request.
# On by default; set to 0 to disable.
# DASHBOARD_WARM=1
# Seconds between warm passes over the cheap pages (weather/stocks/balances/logs/…).
# DASHBOARD_WARM_INTERVAL=60
# Seconds between warm passes over the BigQuery-backed pages (Activity / Last-48). These
# cost a query each, so they are NOT warmed by default (0). Set a value (e.g. 300) to opt
# in — keep it >= their TTL so you don't re-bill BigQuery faster than necessary.
# DASHBOARD_WARM_BQ_INTERVAL=0

# --- Location & timezone ---
# Leave LAT/LON blank to AUTO-DETECT your current location from the server's
# network (and adopt its timezone). Set them to pin a specific spot. These also define
# the weather card's "Home" toggle — which, when LAT/LON are blank, defaults to ZIP 20007
# (Washington, DC); set LAT/LON here to change Home to somewhere else. "Current" uses the
# phone's GPS regardless.
DASHBOARD_LAT=
DASHBOARD_LON=
DASHBOARD_LOCATION=
# Timezone defaults to the Mac mini's system timezone. Override only to pin one.
# DASHBOARD_TZ=America/New_York

# --- Market data: Twelve Data (free tier 800/day) https://twelvedata.com/ ---
TWELVEDATA_KEY=
STOCK_SYMBOLS=SPY,NVDA,VEEV

# --- Mortgage rate: pulled from BigQuery via the sidecar (/mortgage) ---
# Table holding the 30-yr rate. Default datahub.mortgage_mnd_30yr (rate_pct dated by rate_date);
# qualified with the billing project unless you give a full project.dataset.table. Override the
# table/columns if yours differ.
# BQ_MORTGAGE_TABLE=datahub.mortgage_mnd_30yr
# BQ_MORTGAGE_DATE_COL=rate_date
# BQ_MORTGAGE_RATE_COL=rate_pct
# Your existing mortgage rate, for the comparison (percent).
USER_MORTGAGE_RATE=6.375
# --- Housing indicator (Case-Shiller, secondary card only): FRED free key (optional) ---
# https://fredaccount.stlouisfed.org/apikeys — the mortgage RATE no longer needs this; without
# it the card just hides the Case-Shiller sub-line.
FRED_KEY=

# --- Rental property (Zillow Zestimate card) ---
PROPERTY_ADDRESS=
# Zillow has no free Zestimate API. Either set a value manually here…
# PROPERTY_ZESTIMATE=525000
# …and/or supply a RapidAPI Zillow key for a live lookup:
# RAPIDAPI_KEY=
# Optional: direct Zillow listing URL the card opens when tapped.
# PROPERTY_ZILLOW_URL=

# --- BigQuery pages (Python sidecar; uses the machine's existing gcloud ADC) ---
# REQUIRED for the afm + Config tabs: "project.dataset".
# (From findmypy: project ecstatic-pod-443723-f6, dataset home_afm.)
BQ_DATASET=
# Billing/default GCP project (defaults to your ADC quota project).
# BQ_PROJECT=
# Activity page = movement segments for one device over the last 24h, computed
# from the appended fix history (default {BQ_DATASET}.afm_latest_live).
# BQ_AFM_HISTORY=your-project.your_dataset.afm_latest_live
# Activity auto-picks the locatable '12 mini'-model device (else the most active)
# and lets you switch it on the Config page. This is only a last-resort fallback
# when no device is reporting location.
# BQ_AFM_DEVICE=iPhone 16
# Movement threshold (meters between fixes) separating Stopped vs Moving. Lower =
# more sensitive. Sub-4-minute runs are merged to absorb GPS jitter.
# BQ_AFM_MOVE_M=200
# "Label location" lets you save an Activity stop as a named place; matched stops then
# show that name + a star. Stored in a known_locs table, created on first use (set
# BQ_KNOWN_LOCS_CREATE=0 to provision it yourself; BQ_KNOWN_LOCS_TABLE overrides the name).
# BQ_KNOWN_LOCS_TABLE=your-project.your_dataset.known_locs
# Charging events: which raw column holds battery status, and which status values
# mean charging vs not. UCH/DCH (charging-up / discharging) are derived from the
# batteryLevel trend, so a plug-in needs Charging + rising level and an unplug needs
# NotCharging + falling level.
# BQ_AFM_CHARGE_COL=batteryStatus
# Max rows for the 48h Transactions tab (raw fix-history table dump via /afm_raw).
# BQ_AFM_RAW_MAX=300
# BQ_AFM_CHARGING_VALUES=Charging
# BQ_AFM_DISCHARGING_VALUES=NotCharging
# Config table (key/value). Auto-created in BQ_DATASET if missing.
# BQ_CONFIG_TABLE=project.dataset.__APP_NAME_LOWER___config
# BQ_CONFIG_CREATE=1
# Balances page = account balances synced from YNAB into BigQuery (account/balance,
# plus optional type/as_of). This is the PRIMARY balances source and lives in its
# own home_ynab dataset (NOT BQ_DATASET, which is the AFM dataset). Defaults to
# {BQ_PROJECT}.home_ynab.ynab_balances. Set MILLIUNITS=1 if the balances are stored
# in YNAB's native milliunits (1/1000 of a dollar).
# BQ_YNAB_TABLE=your-project.home_ynab.ynab_balances
# BQ_YNAB_MILLIUNITS=0
# Fallback only: a per-account snapshot the budget sheet pushes into BigQuery on a
# timer (see Deploy/balances_sync.gs), used if the YNAB table is empty/missing.
# Defaults to {BQ_DATASET}.__APP_NAME_LOWER___balances.
# BQ_BALANCES_TABLE=your-project.your_dataset.__APP_NAME_LOWER___balances
# Generic /query page (the standalone /screen/bigquery route).
# BQ_QUERY=SELECT name, SUM(number) AS total FROM `bigquery-public-data.usa_names.usa_1910_2013` WHERE state = 'CA' GROUP BY name ORDER BY total DESC LIMIT 10
BQ_TITLE=BigQuery
# BQ_MAX_ROWS=100
# Sidecar port (Vapor reaches it at BQ_SIDECAR_URL, default http://127.0.0.1:8099).
BQ_SIDECAR_PORT=8099
# BQ_SIDECAR_URL=http://127.0.0.1:8099

# --- Smart Home page (event log the ha-events service syncs to Google Drive) ---
# The Smart Home tab summarizes summary_latest.json + the newest events_*.jsonl from
# the Drive-synced 'Smart Home Events' folder. Auto-detected under the Google Drive
# for Desktop mount (Private/Home/Smart Home Events); set this only to override.
# SMARTHOME_DIR=~/Library/CloudStorage/GoogleDrive-you@example.com/My Drive/Private/Home/Smart Home Events

# --- Messages page (recent iMessage/SMS from a Drive-synced export + latest Gmail) ---
# iMessage/SMS are read from a Drive-synced folder of .jsonl/.json exports (newest first;
# flexible fields: sender/handle/from, text/body/message, date/ts, is_from_me/direction).
# Auto-detected under the Google Drive mount (Private/Home/Messages); set this to override.
# MESSAGES_DIR=~/Library/CloudStorage/GoogleDrive-you@example.com/My Drive/Private/Home/Messages
# Latest emails: one Google app-password per account (GMAIL_<n>_USER / GMAIL_<n>_PASS,
# n = 1..8). App-passwords (https://myaccount.google.com/apppasswords), NOT real passwords.
# GMAIL_1_USER=you@gmail.com
# GMAIL_1_PASS=
# GMAIL_2_USER=you@othermail.com
# GMAIL_2_PASS=

# --- System: Logs page (tail of the Mac's ~/log directory) ---
# LOG_DIR=~/log
# LOG_MAX_FILES=8
# LOG_TAIL_LINES=40

# --- System: Repos page (git + deploy status) ---
# Scans REPOS_DIR for every git repo (recursive, depth-bounded; skips node_modules,
# .venv, build dirs, and won't descend into a repo). Defaults to ~/Dropbox/Source — all
# your projects. An explicit repos.json/repos.txt in that dir (paths or names) overrides
# the scan. Deploy status comes from a per-repo marker file (.last_deploy / .deployed_at)
# if the deploy tooling leaves one, else it is derived from git (clean+in-sync vs ahead/dirty).
# Repos are listed newest-commit-first, each with its last 5 commits (tap to expand).
# REPOS_DIR=~/Dropbox/Source
# OPTIONAL: enable GitHub features on the Repos page — latest CI result, open PRs +
# unmerged branches, and the 1-click "Ship" (create PR → merge → delete branch). Off by
# default (the page stays purely local + fast). The token's scope determines what works:
# `actions:read` for CI; `repo` (read) for PR/branch listing; `repo` (write) for Ship.
# Lookups are best-effort and bounded by REPOS_CI_BUDGET seconds so a slow API never stalls.
# REPOS_GH_TOKEN=
# REPOS_CI_BUDGET=8
# Push an APNs alert when a NEW open PR or unmerged branch appears. 0 = OFF (default; each
# poll makes GitHub API calls). Needs APNS_* configured + the token above.
# DASHBOARD_REPO_WATCH_INTERVAL=0

# --- System: Schedrunner status page (scheduled-job summary) ---
# Reads schedrunner's status artifact under SCHEDRUNNER_DIR (status.json / state.json /
# runs.json, or a per-job state dir), or point SCHEDRUNNER_STATUS at the exact file or
# directory. Jobs are read flexibly (name + last/next run + ok/exit/status); if no status
# file is found it falls back to tailing the latest schedrunner *.log.
# SCHEDRUNNER_STATUS=~/Dropbox/Source/schedrunner/state
# Sched Logs page: per-script status parsed from schedrunner's per-script *.log files.
# SCHEDRUNNER_LOG_DIR=~/Dropbox/Source/schedrunner/log

# --- Docs page (Markdown browser over Google Drive /Private) ---
# Auto-detected under the Google Drive for Desktop mount (My Drive/Private); set to override.
# DOCS_DIR=~/Library/CloudStorage/GoogleDrive-you@example.com/My Drive/Private
# Local mirror so Docs is ALWAYS available even when Drive files are "online-only" /
# the Drive app is closed / you're offline. `make docs` (and `make update`) rsync the
# /Private Markdown tree here, and the sidecar reads it in preference to the live mount.
# DOCS_MIRROR=~/.cache/__APP_NAME_LOWER__/docs

# --- Push notifications (APNs): log-failure alerts + Live Activity updates ---
# Optional; push stays OFF until a key is provided. SIMPLEST setup: create an APNs Auth Key
# at developer.apple.com/account → Keys → + (enable Apple Push Notifications), then just DROP
# the downloaded AuthKey_<ID>.p8 file into ~/.config/__APP_NAME_LOWER__/apns/ — that's it. Everything
# else is auto-derived: Key ID from the filename, Team ID from your iOS build team, bundle id
# from the app. (Or enter the key on the in-app Settings page instead of the file.)
# Overrides if you want them (none are required when you drop the file):
# APNS_KEY_DIR=~/.config/__APP_NAME_LOWER__/apns
# APNS_KEY_PATH=~/.secrets/AuthKey_ABC123DEFG.p8
# APNS_KEY_P8=
# APNS_KEY_ID=ABC123DEFG    # auto from the .p8 filename
# APNS_TEAM_ID=ABCDE12345   # auto from DEVELOPMENT_TEAM (your build team)
# APNS_BUNDLE_ID=__BUNDLE_ID__   # auto from the app bundle id
# Use Apple's sandbox gateway for development-signed builds installed from Xcode/OTA;
# leave unset (production gateway) for TestFlight/App Store builds. Set to "sandbox".
# APNS_ENV=sandbox
# Where to persist registered device tokens (defaults to the server working dir).
# APNS_TOKEN_STORE=~/.cache/__APP_NAME_LOWER__/push_tokens.json
# How often (seconds) to poll the logs for new failures before alerting (default 120, min 30).
# DASHBOARD_LOG_WATCH_INTERVAL=120
# Live Activity updates: push the AFM current-state to the lock-screen Live Activity on a
# timer. 0 = OFF (default) — each poll hits the sidecar /afm (BigQuery), so opt in knowingly.
# DASHBOARD_LIVE_ACTIVITY_INTERVAL=0
# Auto-dismiss the Live Activity when the tracked device's status CHANGES into this AFM
# category (a transition) — 'stopped' = dismiss on arrival. DASHBOARD_LIVE_ACTIVITY_DISMISS_ON.
# DASHBOARD_LIVE_ACTIVITY_DISMISS_ON=stopped
# Silent background-refresh push: wakes the iOS app on a timer to re-pull its offline cache so
# it's current the moment you open it, even while closed. Cheap (no BigQuery — just a push that
# triggers the app's own cheap refresh); iOS still throttles delivery. Default 1800s; 0 = OFF.
# DASHBOARD_SILENT_PUSH_INTERVAL=1800
# Notification on/off switches (also toggleable in-app on the Settings page). Master switch +
# per-type; all default true. Setting the master false silences ALL alert pushes regardless of
# the per-type flags. (Does not affect the silent background-refresh push above — that's data.)
# DASHBOARD_NOTIFY_ENABLED=true
# DASHBOARD_NOTIFY_LOG_FAILURES=true
# DASHBOARD_NOTIFY_REPOS=true

# --- Native iOS auto-deploy ---
# Now toggled IN THE APP: Settings → Deploy → "Auto-build iOS app on deploy" (no .env needed).
# When on, `make deploy` rebuilds + republishes the native app IN THE BACKGROUND, but only when
# a native source (App/, Widget/, project.yml, Config.xcconfig) changed since the last build —
# so it never delays the web deploy and is a no-op for content-only changes. Needs a signed-in
# Xcode + an unlocked login keychain (unattended runs: see RUNBOOK keychain note).
# Setting DEPLOY_IOS here still works as an explicit override if you prefer .env.
# DEPLOY_IOS=0

# --- In-app Settings page (enter config/secrets in the app instead of this file) ---
# The Settings page (System → Settings) stores values in Google Secret Manager via the Mac's
# Application Default Credentials. Resolution everywhere is: a value set HERE in .env wins,
# else the app-entered value, else the built-in default — so this file is now optional.
# GCP setup is AUTOMATIC: `make deploy`/`make update` runs Deploy/setup_secrets.sh, which
# enables the Secret Manager API + grants your ADC identity access (idempotent; `make
# secrets-setup` to run it alone). It skips cleanly if gcloud is missing.
# Force the local-file backend instead (0600 ~/.config/__APP_NAME_LOWER__/secrets.json): SECRETS_BACKEND=file
# SECRETS_BACKEND=
# SECRETS_SM_NAME=__APP_NAME_LOWER__-secrets
