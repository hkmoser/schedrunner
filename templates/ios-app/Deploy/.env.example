# Copy to Deploy/.env and fill in. Deploy/.env is git-ignored — never commit secrets.
# Loaded by the server (via launchd) and by the deploy scripts.

# --- Tailscale host (REQUIRED — your Mac mini's MagicDNS name; `tailscale status`) ---
# Example: macmini.tailnet-abcd.ts.net  (no scheme, no trailing slash)
TS_HOST=

# --- Server ---
PORT=8080
# WEB_DIST is set automatically by `make deploy`; override only if you relocate the repo.
# WEB_DIST=/Users/you/Dropbox/Source/__APP_NAME__/Web/dist

# --- Background cache warming ---
# Keep providers fresh on a timer so the app always shows the latest on open.
# DASHBOARD_WARM=1
# DASHBOARD_WARM_INTERVAL=60   # seconds between warm passes (default 60)

# --- Location & timezone (optional — auto-detected when blank) ---
DASHBOARD_LAT=
DASHBOARD_LON=
DASHBOARD_LOCATION=
# DASHBOARD_TZ=America/New_York

# --- BigQuery sidecar (optional — disabled by default; see DEVELOPMENT.md) ---
# BQ_SIDECAR_PORT=8099
# BQ_SIDECAR_URL=http://127.0.0.1:8099
# BQ_DATASET=your-project.your_dataset

# --- Push notifications (APNs — optional; see DEVELOPMENT.md) ---
# Drop an APNs Auth Key (.p8) into ~/.config/__APP_NAME_LOWER__/apns/ to enable push.
# APNS_KEY_DIR=~/.config/__APP_NAME_LOWER__/apns
# APNS_ENV=sandbox       # use "sandbox" for Xcode/OTA dev builds
# DASHBOARD_SILENT_PUSH_INTERVAL=1800   # background refresh wake (0 = off)
# DASHBOARD_NOTIFY_ENABLED=true

# --- In-app Settings page (optional — Google Secret Manager via ADC) ---
# SECRETS_BACKEND=file   # use file backend (~/.config/__APP_NAME_LOWER__/secrets.json) instead of GSM
# SECRETS_SM_NAME=__APP_NAME_LOWER__-secrets
