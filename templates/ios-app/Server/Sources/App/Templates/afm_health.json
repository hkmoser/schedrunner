{
  "type": "screen",
  "style": { "background": "$bg" },
  "children": [
    {
      "type": "scroll",
      "children": [
        {
          "type": "vstack",
          "style": { "spacing": 12, "padding": 16 },
          "children": [
            {
              "type": "hstack",
              "style": { "align": "center", "spacing": 8 },
              "children": [
                { "type": "text", "binding": "afmhealth.title", "style": { "font": "largeTitle", "weight": "bold", "color": "$textPrimary" } },
                { "type": "spacer" },
                { "type": "text", "binding": "meta.updatedAtFormatted", "style": { "font": "caption", "color": "$textSecondary" }, "action": { "type": "refresh" } }
              ]
            },
            { "type": "text", "binding": "afmhealth.subtitleFormatted", "style": { "font": "caption", "color": "$textSecondary" } },

            {
              "type": "card",
              "style": { "background": "$cardBg", "cornerRadius": 16, "padding": 14 },
              "children": [
                {
                  "type": "hstack",
                  "style": { "align": "center", "spacing": 8 },
                  "children": [
                    { "type": "text", "props": { "text": "Last 24h" }, "style": { "font": "headline", "weight": "semibold", "color": "$textPrimary" } },
                    { "type": "spacer" },
                    { "type": "badge", "binding": "afmhealth.statusFormatted", "style": { "color": "afmhealth.statusColor" } }
                  ]
                },
                { "type": "text", "binding": "afmhealth.summaryFormatted", "style": { "font": "caption", "color": "$textSecondary" } },
                { "type": "barChart", "binding": "afmhealth.runChart.bars", "style": { "height": 120 } },
                { "type": "text", "binding": "afmhealth.runChart.captionFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
              ]
            },

            { "type": "text", "props": { "text": "Run timeline (newest first)" }, "style": { "font": "headline", "weight": "semibold", "color": "$textPrimary" } },
            { "type": "text", "binding": "afmhealth.emptyFormatted", "style": { "font": "subhead", "color": "$textSecondary", "align": "center" } },
            {
              "type": "vstack",
              "props": { "repeat": "afmhealth.runs" },
              "style": { "spacing": 8 },
              "children": [
                {
                  "type": "card",
                  "style": { "background": "$cardBg", "cornerRadius": 12, "padding": 12 },
                  "children": [
                    {
                      "type": "hstack",
                      "style": { "align": "center", "spacing": 10 },
                      "children": [
                        {
                          "type": "vstack",
                          "style": { "spacing": 2 },
                          "children": [
                            { "type": "text", "binding": "item.timeFormatted", "style": { "font": "subhead", "weight": "semibold", "color": "$textPrimary" } },
                            { "type": "text", "binding": "item.metaFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
                          ]
                        },
                        { "type": "spacer" },
                        { "type": "badge", "binding": "item.outcomeFormatted", "style": { "color": "item.color" } }
                      ]
                    },
                    { "type": "text", "binding": "item.reasonFormatted", "style": { "font": "caption", "color": "$down" } },
                    {
                      "type": "disclosure",
                      "binding": "item.backoffLabel",
                      "props": { "fallback": "", "open": false },
                      "children": [
                        {
                          "type": "vstack",
                          "props": { "repeat": "item.backoffs" },
                          "style": { "spacing": 4 },
                          "children": [
                            { "type": "code", "binding": "item.lineFormatted", "style": { "color": "#ffd166" } }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
