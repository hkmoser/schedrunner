{
  "type": "screen",
  "style": { "background": "$bg" },
  "children": [
    {
      "type": "scroll",
      "children": [
        {
          "type": "vstack",
          "style": { "spacing": 12, "padding": 16 },
          "children": [
            {
              "type": "hstack",
              "style": { "align": "center" },
              "children": [
                { "type": "text", "binding": "known.title", "style": { "font": "largeTitle", "weight": "bold", "color": "$textPrimary" } },
                { "type": "spacer" },
                { "type": "text", "props": { "text": "Activity" }, "style": { "font": "caption", "weight": "semibold", "color": "$accent" }, "action": { "type": "navigate", "urlBinding": "known.backHref" } }
              ]
            },
            { "type": "text", "binding": "known.subtitleFormatted", "style": { "font": "caption", "color": "$textSecondary" } },
            { "type": "text", "binding": "known.error", "style": { "font": "caption", "color": "$down" } },
            {
              "type": "card",
              "style": { "background": "$cardBg", "cornerRadius": 20, "padding": 16 },
              "children": [
                {
                  "type": "vstack",
                  "props": { "repeat": "known.fields" },
                  "children": [
                    { "type": "field", "binding": "item" }
                  ]
                }
              ]
            },
            {
              "type": "button",
              "props": { "text": "Save location" },
              "action": { "type": "submit", "url": "/known_locs" }
            },
            { "type": "text", "binding": "known.countFormatted", "style": { "font": "headline", "weight": "semibold", "color": "$textPrimary" } },
            {
              "type": "vstack",
              "props": { "repeat": "known.locs" },
              "style": { "spacing": 8 },
              "children": [
                {
                  "type": "card",
                  "style": { "background": "$cardBg", "cornerRadius": 14, "padding": 12 },
                  "children": [
                    {
                      "type": "hstack",
                      "style": { "align": "center", "spacing": 8 },
                      "children": [
                        { "type": "image", "props": { "name": "star.fill" }, "style": { "color": "#ffd166" } },
                        { "type": "text", "binding": "item.name", "style": { "font": "body", "weight": "semibold", "color": "$textPrimary" } },
                        { "type": "spacer" },
                        { "type": "text", "binding": "item.metaFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
