{
  "type": "screen",
  "style": { "background": "$bg" },
  "children": [
    {
      "type": "scroll",
      "children": [
        {
          "type": "vstack",
          "style": { "spacing": 14, "padding": 16 },
          "children": [
            {
              "type": "hstack",
              "style": { "align": "center" },
              "children": [
                { "type": "text", "binding": "docs.title", "style": { "font": "largeTitle", "weight": "bold", "color": "$textPrimary" } },
                { "type": "spacer" },
                { "type": "text", "binding": "meta.updatedAtFormatted", "style": { "font": "caption", "color": "$textSecondary" }, "action": { "type": "refresh" } }
              ]
            },
            { "type": "text", "binding": "docs.subtitleFormatted", "style": { "font": "caption", "color": "$accent" } },
            {
              "type": "text",
              "binding": "docs.upFormatted",
              "style": { "font": "subhead", "weight": "semibold", "color": "$textPrimary" },
              "action": { "type": "navigate", "urlBinding": "docs.upHref" }
            },
            {
              "type": "card",
              "style": { "background": "$cardBg", "cornerRadius": 16, "padding": 8 },
              "children": [
                {
                  "type": "vstack",
                  "props": { "repeat": "docs.entries" },
                  "style": { "spacing": 0 },
                  "children": [
                    {
                      "type": "hstack",
                      "style": { "align": "center", "spacing": 12, "padding": 10 },
                      "action": { "type": "navigate", "urlBinding": "item.navHref" },
                      "children": [
                        { "type": "image", "binding": "item.icon", "style": { "font": "title3", "color": "$accent" } },
                        {
                          "type": "vstack",
                          "style": { "spacing": 2 },
                          "children": [
                            { "type": "text", "binding": "item.name", "style": { "font": "body", "weight": "semibold", "color": "$textPrimary" } },
                            { "type": "text", "binding": "item.metaFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
                          ]
                        },
                        { "type": "spacer" },
                        { "type": "image", "props": { "name": "chevron.right" }, "style": { "font": "caption", "color": "$textSecondary" } }
                      ]
                    }
                  ]
                }
              ]
            },
            { "type": "text", "binding": "docs.emptyFormatted", "style": { "font": "subhead", "color": "$textSecondary", "align": "center" } },
            { "type": "markdown", "binding": "docs.markdown" }
          ]
        }
      ]
    }
  ]
}
