{
  "type": "screen",
  "style": { "background": "$bg" },
  "children": [
    {
      "type": "scroll",
      "children": [
        {
          "type": "vstack",
          "style": { "spacing": 16, "padding": 16 },
          "children": [
            {
              "type": "hstack",
              "style": { "align": "center" },
              "children": [
                { "type": "text", "binding": "messages.title", "style": { "font": "largeTitle", "weight": "bold", "color": "$textPrimary" } },
                { "type": "spacer" },
                { "type": "text", "binding": "meta.updatedAtFormatted", "style": { "font": "caption", "color": "$textSecondary" }, "action": { "type": "refresh" } }
              ]
            },
            { "type": "text", "binding": "messages.subtitleFormatted", "style": { "font": "caption", "color": "$textSecondary" } },
            { "type": "text", "binding": "messages.emptyFormatted", "style": { "font": "subhead", "color": "$textSecondary", "align": "center" } },
            {
              "type": "card",
              "style": { "background": "$cardBg", "cornerRadius": 20, "padding": 16 },
              "children": [
                { "type": "text", "props": { "text": "Sources" }, "style": { "font": "subhead", "weight": "semibold", "color": "$textSecondary" } },
                {
                  "type": "vstack",
                  "props": { "repeat": "messages.sources" },
                  "style": { "spacing": 10 },
                  "children": [
                    {
                      "type": "hstack",
                      "style": { "align": "center", "spacing": 8 },
                      "children": [
                        {
                          "type": "vstack",
                          "style": { "spacing": 2 },
                          "children": [
                            { "type": "text", "binding": "item.label", "style": { "font": "body", "weight": "semibold", "color": "$textPrimary" } },
                            { "type": "text", "binding": "item.metaFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
                          ]
                        },
                        { "type": "spacer" },
                        { "type": "badge", "binding": "item.status", "style": { "color": "item.direction" } }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "vstack",
              "props": { "repeat": "messages.groups" },
              "style": { "spacing": 16 },
              "children": [
                {
                  "type": "card",
                  "style": { "background": "$cardBg", "cornerRadius": 20, "padding": 16 },
                  "children": [
                    {
                      "type": "hstack",
                      "style": { "align": "center", "spacing": 10 },
                      "children": [
                        { "type": "image", "binding": "item.icon", "style": { "font": "title3", "color": "$accent" } },
                        { "type": "text", "binding": "item.title", "style": { "font": "headline", "weight": "semibold", "color": "$textPrimary" } }
                      ]
                    },
                    { "type": "divider", "style": { "color": "$divider" } },
                    {
                      "type": "vstack",
                      "props": { "repeat": "item.items" },
                      "style": { "spacing": 12 },
                      "children": [
                        {
                          "type": "hstack",
                          "style": { "align": "center", "spacing": 12 },
                          "children": [
                            { "type": "image", "binding": "item.icon", "style": { "font": "body", "color": "$textSecondary" } },
                            {
                              "type": "vstack",
                              "style": { "spacing": 2 },
                              "children": [
                                { "type": "text", "binding": "item.titleFormatted", "style": { "font": "body", "weight": "semibold", "color": "$textPrimary" } },
                                { "type": "text", "binding": "item.detailFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
                              ]
                            },
                            { "type": "spacer" },
                            { "type": "text", "binding": "item.timeFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
