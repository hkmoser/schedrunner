{
  "type": "screen",
  "style": {
    "background": "$bg"
  },
  "children": [
    {
      "type": "scroll",
      "children": [
        {
          "type": "vstack",
          "style": {
            "spacing": 16,
            "padding": 16
          },
          "children": [
            {
              "type": "hstack",
              "style": { "align": "center" },
              "children": [
                {
                  "type": "text",
                  "props": { "text": "__APP_NAME__" },
                  "style": {
                    "font": "largeTitle",
                    "weight": "bold",
                    "color": "$textPrimary"
                  }
                },
                { "type": "spacer" },
                {
                  "type": "text",
                  "binding": "meta.updatedAtFormatted",
                  "style": {
                    "font": "caption",
                    "color": "$textSecondary"
                  },
                  "action": { "type": "refresh" }
                }
              ]
            },
            {
              "type": "card",
              "style": {
                "background": "$cardBg",
                "cornerRadius": 20,
                "padding": 20
              },
              "children": [
                {
                  "type": "text",
                  "binding": "welcome.headline",
                  "style": {
                    "font": "headline",
                    "weight": "semibold",
                    "color": "$textPrimary"
                  }
                },
                {
                  "type": "text",
                  "binding": "welcome.body",
                  "style": {
                    "font": "body",
                    "color": "$textSecondary"
                  }
                }
              ]
            },
            {
              "type": "card",
              "style": {
                "background": "$cardBg",
                "cornerRadius": 20,
                "padding": 20
              },
              "children": [
                {
                  "type": "text",
                  "props": { "text": "Getting Started" },
                  "style": {
                    "font": "headline",
                    "weight": "semibold",
                    "color": "$textPrimary"
                  }
                },
                {
                  "type": "text",
                  "props": { "text": "1. Edit Server/Sources/App/Providers/WelcomeProvider.swift — add your own data fetch and return it as a JSONValue dictionary." },
                  "style": { "font": "caption", "color": "$textSecondary" }
                },
                {
                  "type": "text",
                  "props": { "text": "2. Edit Server/Sources/App/Templates/screen.json — bind new fields with \"binding\": \"welcome.yourKey\" and reshape the layout." },
                  "style": { "font": "caption", "color": "$textSecondary" }
                },
                {
                  "type": "text",
                  "props": { "text": "3. Run make deploy — the PWA and native app will pick up the change without a client update." },
                  "style": { "font": "caption", "color": "$textSecondary" }
                },
                {
                  "type": "text",
                  "props": { "text": "See DEVELOPMENT.md for full docs: adding screens, enabling BigQuery, push notifications, and the next channel." },
                  "style": { "font": "caption2", "color": "$accent" }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
