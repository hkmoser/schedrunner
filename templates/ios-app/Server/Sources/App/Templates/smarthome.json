{
  "type": "screen",
  "style": { "background": "$bg" },
  "children": [
    {
      "type": "scroll",
      "children": [
        {
          "type": "vstack",
          "style": { "spacing": 16, "padding": 16 },
          "children": [
            {
              "type": "hstack",
              "style": { "align": "center" },
              "children": [
                { "type": "text", "binding": "smarthome.title", "style": { "font": "largeTitle", "weight": "bold", "color": "$textPrimary" } },
                { "type": "spacer" },
                { "type": "text", "binding": "smarthome.subtitleFormatted", "style": { "font": "caption", "color": "$textSecondary" }, "action": { "type": "refresh" } }
              ]
            },
            {
              "type": "card",
              "style": { "background": "$cardBg", "cornerRadius": 20, "padding": 16 },
              "children": [
                {
                  "type": "hstack",
                  "style": { "align": "center", "spacing": 10 },
                  "children": [
                    { "type": "text", "props": { "text": "Status" }, "style": { "font": "subhead", "color": "$textSecondary" } },
                    { "type": "spacer" },
                    { "type": "badge", "binding": "smarthome.statusFormatted", "style": { "color": "smarthome.statusDirection" } }
                  ]
                },
                { "type": "text", "binding": "smarthome.countsFormatted", "style": { "font": "caption", "color": "$textSecondary" } },
                { "type": "divider", "style": { "color": "$divider" } },
                {
                  "type": "vstack",
                  "props": { "repeat": "smarthome.sources" },
                  "style": { "spacing": 12 },
                  "children": [
                    {
                      "type": "hstack",
                      "style": { "align": "center", "spacing": 12 },
                      "children": [
                        { "type": "image", "binding": "item.icon", "style": { "font": "title3", "color": "item.color" } },
                        {
                          "type": "vstack",
                          "style": { "spacing": 2 },
                          "children": [
                            { "type": "text", "binding": "item.label", "style": { "font": "body", "weight": "semibold", "color": "$textPrimary" } },
                            { "type": "text", "binding": "item.metaFormatted", "style": { "font": "caption", "color": "item.direction" } }
                          ]
                        },
                        { "type": "spacer" },
                        { "type": "badge", "binding": "item.lastHourFormatted", "style": { "color": "$textSecondary" } }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "card",
              "style": { "background": "$cardBg", "cornerRadius": 20, "padding": 16 },
              "children": [
                {
                  "type": "hstack",
                  "style": { "align": "center", "spacing": 10 },
                  "children": [
                    { "type": "text", "props": { "text": "Filters · 24h" }, "style": { "font": "headline", "weight": "semibold", "color": "$textPrimary" } },
                    { "type": "spacer" },
                    { "type": "text", "props": { "text": "Reset" }, "style": { "font": "caption", "weight": "semibold", "color": "$accent" }, "action": { "type": "navigate", "urlBinding": "smarthome.defaultsHref" } }
                  ]
                },
                { "type": "text", "binding": "smarthome.filterSummaryFormatted", "style": { "font": "caption", "color": "$textSecondary" } },
                {
                  "type": "hstack",
                  "style": { "align": "center", "spacing": 10 },
                  "children": [
                    { "type": "text", "props": { "text": "Sources" }, "style": { "font": "subhead", "weight": "semibold", "color": "$textSecondary" } },
                    { "type": "spacer" },
                    { "type": "text", "props": { "text": "All" }, "style": { "font": "caption", "weight": "semibold", "color": "$accent" }, "action": { "type": "navigate", "urlBinding": "smarthome.allSourcesHref" } }
                  ]
                },
                {
                  "type": "hstack",
                  "props": { "repeat": "smarthome.sourceFilters" },
                  "style": { "spacing": 8, "wrap": true },
                  "children": [
                    {
                      "type": "badge",
                      "binding": "item.labelFormatted",
                      "style": { "color": "item.color" },
                      "action": { "type": "navigate", "urlBinding": "item.navHref" }
                    }
                  ]
                },
                { "type": "divider", "style": { "color": "$divider" } },
                {
                  "type": "hstack",
                  "style": { "align": "center", "spacing": 10 },
                  "children": [
                    { "type": "text", "props": { "text": "Types" }, "style": { "font": "subhead", "weight": "semibold", "color": "$textSecondary" } },
                    { "type": "spacer" },
                    { "type": "text", "props": { "text": "All" }, "style": { "font": "caption", "weight": "semibold", "color": "$accent" }, "action": { "type": "navigate", "urlBinding": "smarthome.allHref" } }
                  ]
                },
                {
                  "type": "hstack",
                  "props": { "repeat": "smarthome.types" },
                  "style": { "spacing": 8, "wrap": true },
                  "children": [
                    {
                      "type": "badge",
                      "binding": "item.labelFormatted",
                      "style": { "color": "item.color" },
                      "action": { "type": "navigate", "urlBinding": "item.navHref" }
                    }
                  ]
                }
              ]
            },
            {
              "type": "card",
              "style": { "background": "$cardBg", "cornerRadius": 20, "padding": 16 },
              "children": [
                { "type": "text", "props": { "text": "Recent events" }, "style": { "font": "headline", "weight": "semibold", "color": "$textPrimary" } },
                { "type": "text", "binding": "smarthome.emptyFormatted", "style": { "font": "subhead", "color": "$textSecondary", "align": "center" } },
                {
                  "type": "vstack",
                  "props": { "repeat": "smarthome.events" },
                  "style": { "spacing": 12 },
                  "children": [
                    {
                      "type": "vstack",
                      "style": { "spacing": 6 },
                      "children": [
                        {
                          "type": "hstack",
                          "style": { "align": "center", "spacing": 12 },
                          "children": [
                            { "type": "image", "binding": "item.icon", "style": { "font": "body", "color": "item.color" } },
                            {
                              "type": "vstack",
                              "style": { "spacing": 2 },
                              "children": [
                                { "type": "text", "binding": "item.title", "style": { "font": "body", "weight": "semibold", "color": "$textPrimary" } },
                                { "type": "text", "binding": "item.detail", "style": { "font": "caption", "color": "$textSecondary" } }
                              ]
                            },
                            { "type": "spacer" },
                            { "type": "text", "binding": "item.timeFormatted", "style": { "font": "caption", "color": "$textSecondary" } }
                          ]
                        },
                        {
                          "type": "disclosure",
                          "binding": "item.detailsLabel",
                          "props": { "fallback": "Details", "open": false },
                          "children": [
                            {
                              "type": "vstack",
                              "props": { "repeat": "item.details" },
                              "style": { "spacing": 4 },
                              "children": [
                                {
                                  "type": "hstack",
                                  "style": { "align": "leading", "spacing": 10 },
                                  "children": [
                                    { "type": "text", "binding": "item.keyFormatted", "style": { "font": "caption", "color": "$textSecondary" } },
                                    { "type": "spacer" },
                                    { "type": "text", "binding": "item.valueFormatted", "style": { "font": "caption", "color": "$textPrimary" } }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
